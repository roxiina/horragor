# ============================================================
# HorRAGor – Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs
# NE JAMAIS commiter le fichier .env (voir .gitignore)
# ============================================================

# --- TMDB API ---
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# CONNEXION BASE DE DONNÉES – Session Pooler (IPv4, port 5432)
# Récupérer l'URL dans : Supabase Dashboard → Connect → Session pooler
# Format : postgresql://postgres.xxxx:your_password@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
#
# ⚠️  NE PAS utiliser la connexion directe (db.xxxx.supabase.co) si votre FAI
#     ne supporte pas l'IPv6 (cas fréquent sur les box Réunion / DOM-TOM).
#     Le Session Pooler utilise IPv4 et contourne ce problème.
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your_password@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# --- Chemins des données locales ---
KAGGLE_CSV_PATH=data/raw/horror_movies_kaggle.csv
IMDB_SQLITE_PATH=data/raw/imdb_horror.db
SPARK_DATA_DIR=data/raw/spark_chunks/

# --- Pipeline ---
# Nombre de pages à extraire depuis TMDB (50 films/page max)
TMDB_MAX_PAGES=20
# Seuil IMDB : nombre minimum de votes pour inclure un film
IMDB_MIN_VOTES=1000
# Seuil de similarité pour le fuzzy matching (0-100)
FUZZY_THRESHOLD=85

# --- Rotten Tomatoes Selenium ---
# Mettre True pour utiliser le navigateur en mode headless
SELENIUM_HEADLESS=True
# Optionnel : chemin du binaire Chrome si non détecté automatiquement
# CHROME_BINARY_PATH=/usr/bin/google-chrome

# --- Logs ---
LOG_LEVEL=INFO
LOG_FILE=logs/horragor.log
